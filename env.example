# Archivo: .env.example
# Carpeta: microservicioMLL/ (raíz del proyecto)

# --- Base de datos ---
# Producción (Neon, ya desplegada, ya migrada): esta es la cadena real.
DATABASE_URL=postgresql://neondb_owner:npg_y8w4RBLTnCjS@ep-withered-fog-ajqawsrq-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Desarrollo/tests sin red: comenta la línea de arriba y usa
# DATABASE_URL=sqlite:///./app.db

# --- Notificaciones por correo (severidad riesgo/critico) ---
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion
SMTP_FROM=tu_correo@gmail.com
ALERT_EMAIL_TO=productor1@correo.com,admin@correo.com
EMAIL_MIN_SEVERIDAD=riesgo

MODELO_VERSION=2.0.0

# --- Notificaciones push / FCM (paso 11: despliegue) ---
# 1. Crea un proyecto en https://console.firebase.google.com (o usa uno ya existente).
# 2. Configuración del proyecto > Cuentas de servicio > Generar nueva clave privada -> descarga
#    el JSON y guárdalo en este servidor (NO lo subas al repo).
# 3. Pon la ruta absoluta a ese archivo en FCM_CREDENTIALS_PATH y FCM_ENABLED=true.
# FCM_MIN_SEVERIDAD=advertencia -> avisa en CUALQUIER anomalía que el ML detecte, no solo
# riesgo/critico (el correo sí se queda solo en riesgo/critico, ver EMAIL_MIN_SEVERIDAD).
FCM_ENABLED=false
FCM_CREDENTIALS_PATH=/ruta/absoluta/a/firebase-service-account.json
FCM_MIN_SEVERIDAD=advertencia
# Minutos mínimos entre dos push de anomalía para el mismo lote+tipo, evita ráfagas si la
# condición persiste en lecturas consecutivas.
FCM_COOLDOWN_MINUTOS=30

# --- Polling en tiempo real (paso 12: monitoreo) ---
# El disparador normal es que el Gestor llame POST /internal/lecturas/nuevas al instante. Esto
# es la red de seguridad: revisa lecturas_ambientales cada POLLING_INTERVALO_SEGUNDOS por si
# el webhook no se llegó a llamar (Gestor caído, red, etc.). POLLING_ENABLED=false lo apaga
# por completo (el servicio queda 100% reactivo, solo webhook).
POLLING_ENABLED=true
POLLING_INTERVALO_SEGUNDOS=30
POLLING_BATCH_SIZE=50

# --- Seguridad entre servicios (Gestor -> MLL, y opcionalmente API móvil -> MLL) ---
# Genera un valor aleatorio largo (ej: openssl rand -hex 32) y ponlo IGUAL en este .env
# y en cada servicio interno que llame al MLL, mandado en el header X-Internal-Api-Key.
# Vacío = sin exigencia (úsalo así solo en desarrollo local).
INTERNAL_API_KEY=

# --- Reentrenamiento automático (ver app/services/reentrenador.py) ---
# Apagado por default: entrenar consume CPU real por varios segundos/minutos. Si lo activas,
# revisa cada REENTRENAMIENTO_INTERVALO_HORAS si ya hay lotes/lecturas nuevas suficientes (misma
# lógica que expone GET /internal/monitoreo/salud) y, si es así, reentrena solo -- sin esto, el
# modelo nunca mejora con datos reales aunque se acumulen, a menos que alguien corra
# scripts/recolectar_datos_reales.py + scripts/train_models.py a mano.
REENTRENAMIENTO_AUTOMATICO_ENABLED=false
REENTRENAMIENTO_INTERVALO_HORAS=24